```gitignore
# =========================
# Python
# =========================
venv/
backend/venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/

# Database (optional)
# Uncomment if you don't want to commit your local database
# *.db

# Environment variables
.env

# =========================
# Node / React
# =========================
node_modules/
dist/

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# IDE
# =========================
.vscode/
!.vscode/extensions.json
.idea/

# =========================
# Operating System
# =========================
.DS_Store
Thumbs.db
```
